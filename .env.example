# Copy to .env and adjust before running `docker compose up`.

# Long random string used to sign session cookies.
# Generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-32-bytes-of-randomness

# Demo user used by bootstrap-demo.sh and the "Sign in as demo" button.
# Override these if you want a different demo identity baked into the build.
DEMO_EMAIL=igor.petrov@cloudexchange.local
DEMO_PASSWORD=cloud24demo
DEMO_DISPLAY_NAME=Игорь Петров

# Public hostname — used for the TLS cert SAN and the mail server hostname.
MAIL_HOSTNAME=mail.cloudexchange.local

# Edge ports. Dev defaults are non-privileged (8080/8443).
# For production set HTTP_PORT=80 and HTTPS_PORT=443.
HTTP_PORT=8080
HTTPS_PORT=8443

# Public origin the browser uses (scheme + host + port). Must match how
# users reach the app so session cookies and CORS line up.
PUBLIC_ORIGIN=https://localhost:8443

# Mail server TLS mode: "manual" (shared cert), "letsencrypt", or empty
# to disable. See docs/TLS.md.
MAIL_SSL_TYPE=manual
